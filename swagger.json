                    }
                }
            }
        },
        "/v1/me?user_id={user_id}": {
            "get": {
                "description": "busca de um usuario pelo seu id",
                "security": [
                    {
                        "bearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "user_id",
                        "in": "path",
                        "description": "id do usuario",
                        "required": "true",
                        "type": "string",
                        "format": "uuid"
